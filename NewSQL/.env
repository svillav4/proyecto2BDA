# Variables de entorno para el laboratorio NewSQL
# Modifica estos valores según necesites

# Versión de YugabyteDB
YB_VERSION=latest

# Puertos para conexiones SQL
YB_NODE1_PORT=5433
YB_NODE2_PORT=5434
YB_NODE3_PORT=5435

# Usuario y contraseña por defecto
YB_USER=yugabyte
YB_PASSWORD=yugabyte

# Número de nodos en el clúster
YB_NODES=3